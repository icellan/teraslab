.idea/
_plans/

# Added by cargo
/target

# Client build artifacts
/client/rust/target
/client/rust/Cargo.lock

# Test client build artifacts
/teraslab-tests/client/target
/teraslab-tests/client/Cargo.lock

# Test results and logs
/teraslab-tests/results/*
!/teraslab-tests/results/.gitkeep

# Generated Docker compose files and configs (runtime artifacts)
/docker/

# Per-scenario E2E compose files and node configs — regenerated at test
# runtime by DockerHelpers (teraslab-tests/client/src/helpers.rs)
/teraslab-tests/docker/docker-compose.ts*.yml
/teraslab-tests/docker/config/ts*-node*.toml

# Coverage reports
tarpaulin-report.json

# Local agent state
/.claude/

# Local working notes (not shipped with the repo)
/docs/superpowers/

# Scenario debug log dumps
/teraslab-tests/client/debug-logs/

# Local release build artifacts (produced by scripts/cut-release.sh / manual builds)
dist/

# Local runtime data artifacts (server/test runs)
*.dat
*.dat.tombstone
*.redb
*.snap
teraslab-data*
teraslab-tombstone*

# Local agent/dev worktrees (not tracked)
.worktrees/
